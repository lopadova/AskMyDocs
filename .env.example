# =============================================================================
# AskMyDocs — environment configuration template
# =============================================================================
# Copy this file to .env and fill in the secrets. Most defaults are tuned for
# a low-cost, production-sensible RAG pipeline using OpenRouter for chat and
# OpenAI for embeddings.
# =============================================================================

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=AskMyDocs
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Maintenance / logging
LOG_CHANNEL=stack
LOG_LEVEL=info

# ── Database (PostgreSQL + pgvector) ───────────────────────────────────────
# Production recommends PostgreSQL 15+ with the `vector` extension installed.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=askmydocs
DB_USERNAME=postgres
DB_PASSWORD=

# ── Session / cache ────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database

# ── Queue / background ingestion ───────────────────────────────────────────
# Controls how kb:ingest-folder and POST /api/kb/ingest dispatch per-document
# jobs. Three supported drivers:
#   sync      → inline, no worker needed (dev default).
#   database  → zero-infra prod. Run `php artisan migrate` to get jobs +
#               failed_jobs tables, then a worker:
#                 php artisan queue:work --queue=kb-ingest
#   redis     → production with Redis. Requires:
#                 composer require predis/predis
#               Optional UI:
#                 composer require laravel/horizon
#                 php artisan horizon
QUEUE_CONNECTION=sync

# Queue name used by kb:ingest-folder and POST /api/kb/ingest.
KB_INGEST_QUEUE=kb-ingest
# Default project_key when the command/API call omits one.
KB_INGEST_DEFAULT_PROJECT=default

# Redis (only required for QUEUE_CONNECTION=redis — uninstalled by default).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=kb-ingest

# ── AI — default providers ─────────────────────────────────────────────────
# Chat provider: openrouter gives access to many models at pay-per-token.
# Embeddings provider: openai is the cheapest high-quality embedding tier.
# Supported values: openai, anthropic, gemini, openrouter, regolo
AI_PROVIDER=openrouter
AI_EMBEDDINGS_PROVIDER=openai

# ── Agentic / MCP ────────────────────────────────────────────────────────
# v5.0 introduced agentic chat; v7.0/W6.3.B retired the Node sidecar
# entirely and routes JSON-RPC through native HTTP / SSE / stdio
# transports via `padosoft/askmydocs-mcp-pack`. The host keeps this
# OFF by default; flip on once at least one row is configured in the
# `mcp_servers` table and a handshake against it succeeds.
AI_AGENTIC_ENABLED=false
# Optional shared-secret token that gates `/api/mcp/internal-auth`,
# the surviving token-presence probe. v7.0/W6.3.B removed the
# companion `/api/mcp/credentials` route (Copilot iter-3 flagged it
# as a latent decrypted-secret pathway reachable by ordinary
# authenticated users when this token is empty); v7.0/W6.3.C will
# drop the probe + this token entirely. Either value is safe today:
# empty leaves the probe accepting all requests, populated requires
# the matching `X-MCP-Internal-Token` header. Decrypted upstream
# auth_config never leaves the Sanctum-protected admin surface
# anymore.
MCP_INTERNAL_AUTH_TOKEN=
# MCP tool-calling behavior. `MAX_ITERATIONS` caps the multi-turn
# tool loop so a misbehaving model can't run away with the budget.
AI_MCP_TOOL_CALL_MAX_ITERATIONS=3
AI_MCP_TOOL_CALL_DEFAULT_CHOICE=auto

# ── padosoft/askmydocs-mcp-pack (v7.0/W6.3.B — authoritative for transport) ──
# v7.0/W6.3.B retired the Node sidecar; tool calls + handshakes now go
# through the package's native MCP transports (HTTP / SSE / stdio).
# The host's inline orchestrator (`App\Mcp\Client\McpToolCallingService`)
# still drives the multi-turn loop and writes the audit rows, but its
# underlying transport calls reach for `McpClient::forServer()` from
# the package.
#
# Knob taxonomy below — read carefully, NOT every line is a kill-switch:
#
#   - "Kill-switches" (`MCP_PACK_CB_ENABLED`, `MCP_PACK_RETRY_ENABLED`,
#     `MCP_PACK_SERVER_HTTP_ENABLED`, `MCP_PACK_ADMIN_ENABLED`):
#     boolean, default OFF — flip ON only when you want the
#     corresponding subsystem live. A fresh install behaves as if
#     these don't exist.
#   - "Tuning values" (`MCP_PACK_TOOL_CALLING_MAX_ITERATIONS`,
#     `MCP_PACK_HANDSHAKE_TTL`, `MCP_PACK_SERVER_HTTP_PREFIX`, ...):
#     active defaults that drive package behavior all the time. You
#     can tune them, but they are NOT off-switches.
#
# Tool-calling iteration budget — package-side only. The kill-switch
# `tool_calling.enabled` in the package config is bound to
# `AI_AGENTIC_ENABLED` above, so the package and the existing host
# code share the same on/off flag. NOTE: the live chat loop in v7.0/W6.3.B
# is still driven by the inline `App\Mcp\Client\McpToolCallingService`,
# which reads `AI_MCP_TOOL_CALL_MAX_ITERATIONS` from `config/mcp.php`
# (above) — NOT the value below. Tuning this knob ONLY takes effect
# once a future cutover (v7.0/W6.3.C) replaces the inline orchestrator
# with the package's own. For now, treat the line below as "the value
# the package WILL use", and `AI_MCP_TOOL_CALL_MAX_ITERATIONS` as
# "the value chat actually uses today".
MCP_PACK_TOOL_CALLING_MAX_ITERATIONS=3
MCP_PACK_TOOL_CHOICE=auto
# Handshake cache TTL (seconds). `0` disables caching entirely.
MCP_PACK_HANDSHAKE_TTL=300
# Host's audit-model subclass — set automatically by config/mcp-pack.php.
# Override only when a host fork wants a different model.
# MCP_PACK_AUDIT_MODEL=
# Server-side surface (DISABLED on AskMyDocs — host has its own MCP
# server routes via `laravel/mcp`). Flip MCP_PACK_SERVER_HTTP_ENABLED
# only on hosts that genuinely want to expose the package's HTTP
# stdio runner.
MCP_PACK_SERVER_HTTP_ENABLED=false
MCP_PACK_SERVER_HTTP_PREFIX=mcp
MCP_PACK_SERVER_HTTP_MIDDLEWARE=api
# Resilience — opt-in circuit-breaker + adaptive retry budget. Both
# layers are independent.
MCP_PACK_CB_ENABLED=false
MCP_PACK_CB_FAILURE_THRESHOLD=5
MCP_PACK_CB_RECOVERY_SECONDS=30
MCP_PACK_RETRY_ENABLED=false
MCP_PACK_RETRY_MAX_ATTEMPTS=3
MCP_PACK_RETRY_BUCKET_SIZE=20
MCP_PACK_RETRY_BUCKET_WINDOW_SECONDS=60
MCP_PACK_RETRY_BASE_BACKOFF_MS=200
MCP_PACK_RETRY_MAX_BACKOFF_MS=5000
# Optional dedicated cache store for breaker/budget state — leave
# unset to use the default app cache.
# MCP_PACK_RESILIENCE_CACHE_STORE=
# Admin REST surface (DISABLED — AskMyDocs has its own admin API).
MCP_PACK_ADMIN_ENABLED=false
MCP_PACK_ADMIN_PREFIX=api/admin/mcp-pack
MCP_PACK_ADMIN_MIDDLEWARE=api

# ── AI — OpenAI ────────────────────────────────────────────────────────────
# Used here for embeddings. `text-embedding-3-small` is the lowest-cost
# 1536-dimension embedding model — matches KB_EMBEDDINGS_DIMENSIONS below.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=4096
OPENAI_TIMEOUT=120

# ── AI — Anthropic (Claude) ────────────────────────────────────────────────
# Anthropic does NOT offer an embeddings endpoint — pair with OpenAI or Gemini
# for embeddings when using Claude as the chat provider.
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TEMPERATURE=0.2
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TIMEOUT=120

# ── AI — Google Gemini ─────────────────────────────────────────────────────
# Gemini supports both chat and embeddings. Note: `text-embedding-004` is
# 768-dim — if you switch to Gemini embeddings you must update
# KB_EMBEDDINGS_DIMENSIONS to 768 and re-index your documents.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDINGS_MODEL=text-embedding-004
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=4096
GEMINI_TIMEOUT=120

# ── AI — OpenRouter (multi-model gateway) ──────────────────────────────────
# Default chat gateway. `openai/gpt-4o-mini` is a good low-cost starting
# point; see https://openrouter.ai/models for alternatives.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=AskMyDocs
OPENROUTER_SITE_URL=
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_TIMEOUT=120

# ── AI — Regolo.ai (by Seeweb) ─────────────────────────────────────────────
# EU-based, GDPR-compliant, OpenAI-compatible REST. Get a key at
# https://dashboard.regolo.ai. Chat, streaming, embeddings, and
# reranking are all supported via the `padosoft/laravel-ai-regolo`
# extension on top of the official `laravel/ai` SDK.
REGOLO_API_KEY=
REGOLO_BASE_URL=https://api.regolo.ai/v1
REGOLO_CHAT_MODEL=Llama-3.3-70B-Instruct
# `cheapest` and `smartest` aliases pick the right model for cost-vs-
# quality shortcuts (see `Lab::Cheapest` / `Lab::Smartest` in laravel/ai).
REGOLO_CHAT_MODEL_CHEAPEST=Llama-3.1-8B-Instruct
REGOLO_CHAT_MODEL_SMARTEST=Llama-3.3-70B-Instruct
REGOLO_EMBEDDINGS_MODEL=Qwen3-Embedding-8B
REGOLO_EMBEDDINGS_DIMENSIONS=4096
REGOLO_RERANKING_MODEL=jina-reranker-v2
REGOLO_TIMEOUT=120
# Provider-level defaults. Per-call overrides via `$options['max_tokens']`
# (e.g. ConversationController::generateTitle capping titles at 60
# tokens) take precedence — RegoloProvider exposes both knobs through
# RegoloAnonymousAgent so the laravel/ai SDK + padosoft/laravel-ai-regolo
# gateway emit `max_tokens` / `temperature` on the Regolo wire request.
REGOLO_MAX_TOKENS=4096
REGOLO_TEMPERATURE=0.2

# ── Knowledge Base — retrieval ────────────────────────────────────────────
# Embedding vector size — must match the embeddings model you use:
#   text-embedding-3-small   → 1536
#   text-embedding-3-large   → 3072
#   text-embedding-004       → 768   (Gemini)
#   Qwen3-Embedding-8B       → 4096  (Regolo / `REGOLO_EMBEDDINGS_DIMENSIONS`)
# When AI_EMBEDDINGS_PROVIDER=regolo, this MUST equal
# REGOLO_EMBEDDINGS_DIMENSIONS above (default 4096) — otherwise the
# pgvector `vector(N)` column will reject rows from the embeddings
# call with a dimension-mismatch error at ingest time.
KB_EMBEDDINGS_DIMENSIONS=1536
# Cosine-similarity floor (0.0–1.0). Lower = more recall, less precision.
KB_MIN_SIMILARITY=0.30
# Default number of chunks returned per query.
KB_DEFAULT_LIMIT=8

# ── Knowledge Base — chunking ──────────────────────────────────────────────
KB_CHUNK_TARGET_TOKENS=512
KB_CHUNK_HARD_CAP_TOKENS=1024
KB_CHUNK_OVERLAP_TOKENS=64

# ── Knowledge Base — reranking (over-retrieve then rerank) ────────────────
KB_RERANKING_ENABLED=true
KB_RERANK_CANDIDATE_MULTIPLIER=3
# Weights must sum to 1.0
KB_RERANK_VECTOR_WEIGHT=0.60
KB_RERANK_KEYWORD_WEIGHT=0.30
KB_RERANK_HEADING_WEIGHT=0.10

# ── Knowledge Base — hybrid search (vector + full-text) ───────────────────
# Enable when your corpus contains product codes, legal refs, acronyms, etc.
# that must be matched exactly. Adds a PostgreSQL FTS query per search.
KB_HYBRID_SEARCH_ENABLED=false
# PostgreSQL text-search language. Must be one of the supported `regconfig`
# names: simple, italian, english, german, french, spanish, portuguese, ...
KB_FTS_LANGUAGE=italian
# Reciprocal Rank Fusion (RRF) constant — 60 is the industry standard.
KB_RRF_K=60
# Weights for the semantic vs. FTS ranked lists during fusion.
KB_HYBRID_SEMANTIC_WEIGHT=0.70
KB_HYBRID_FTS_WEIGHT=0.30

# ── Knowledge Base — embedding cache ──────────────────────────────────────
# DB-backed cache keyed by SHA-256(text) + provider + model. Avoids paying
# the API cost twice for identical queries or re-ingestion of unchanged docs.
KB_EMBEDDING_CACHE_ENABLED=true
# Scheduler deletes rows not used in the last N days. 0 = never prune.
KB_EMBEDDING_CACHE_RETENTION_DAYS=30
# v4.2 — kb.prune-embedding-cache Flow inserts a conditional approval gate
# when the projected eviction count exceeds this threshold. Keeps small daily
# evictions flowing without operator intervention while surfacing large
# accidental sweeps (e.g. a misconfigured KB_EMBEDDING_CACHE_RETENTION_DAYS)
# for review. Set to 0 (or any negative value) to disable the gate entirely
# (every prune runs without approval, recovering pre-v4.2 behaviour).
KB_EMBEDDING_CACHE_APPROVAL_THRESHOLD=5000

# ── Knowledge Base — document deletion ────────────────────────────────────
# When true (default), kb:delete and DELETE /api/kb/documents mark documents
# as deleted (deleted_at + cascade to chunks) without removing the original
# file. The scheduled `kb:prune-deleted` command hard-deletes soft-deleted
# documents older than KB_SOFT_DELETE_RETENTION_DAYS and removes the file
# from disk at that time.
#
# When false, deletions are immediately hard: document + chunks + file
# are purged in a single operation. You can still force a hard delete on a
# per-call basis via `--force` (artisan) or `"force": true` (API).
KB_SOFT_DELETE_ENABLED=true
KB_SOFT_DELETE_RETENTION_DAYS=30

# ── Knowledge Base — storage disk ─────────────────────────────────────────
# Laravel filesystem disk used to read markdown documents. Defaults to
# storage/app/kb. Change to `s3` to ingest from S3 (see comments below).
KB_FILESYSTEM_DISK=kb
# Optional prefix prepended to every relative path passed to kb:ingest.
KB_PATH_PREFIX=
# Direct overrides for the built-in `kb` disk (skipped when using s3):
KB_DISK_DRIVER=local
# KB_DISK_ROOT=/absolute/path/to/markdown/root

# KB per-project disk override (optional JSON map: project_key -> disk name).
# Each listed project routes ingest/search/delete through the named disk
# instead of the default canonical disk. Projects not listed fall back to
# KB_FILESYSTEM_DISK.
# KB_PROJECT_DISKS={"hr-portal":"kb-hr","legal-vault":"kb-legal"}

# KB raw-ingestion disk (OmegaWiki three-state pipeline: raw → curated →
# canonical). Holds unprocessed PDFs / Word / notes awaiting promotion.
KB_RAW_DISK=kb-raw
# KB_RAW_DISK_ROOT=/absolute/path/to/kb-raw (defaults to storage/app/kb-raw)

# --- Alternative storage backends for the KB (set KB_FILESYSTEM_DISK to one)--

# Cloudflare R2 (S3-compatible, zero egress fees). Set KB_FILESYSTEM_DISK=r2.
# Requires: composer require league/flysystem-aws-s3-v3 "^3.0"
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_BUCKET=
# AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Google Cloud Storage. Set KB_FILESYSTEM_DISK=gcs.
# Requires: composer require superbalist/laravel-google-cloud-storage
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_KEY_FILE=storage/app/gcs-credentials.json
# GOOGLE_CLOUD_BUCKET=
# GOOGLE_CLOUD_PATH_PREFIX=
# GOOGLE_CLOUD_STORAGE_API_URI=

# MinIO (S3-compatible, self-hosted). Set KB_FILESYSTEM_DISK=minio.
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_BUCKET=askmydocs
# MINIO_REGION=us-east-1

# ── AWS / S3 credentials (only when KB_FILESYSTEM_DISK=s3) ────────────────
# Requires: composer require league/flysystem-aws-s3-v3 "^3.0"
# Note: set KB_FILESYSTEM_DISK=s3 above to route KB ingestion through the
# fully-configured "s3" disk (defined in config/filesystems.php). Do NOT
# set KB_DISK_DRIVER=s3 on its own — the "kb" disk does not carry S3 keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Chat logging ──────────────────────────────────────────────────────────
# When enabled, every chat interaction is persisted for analytics/audit.
CHAT_LOG_ENABLED=false
CHAT_LOG_DRIVER=database
CHAT_LOG_DB_CONNECTION=
# Scheduler deletes chat_logs rows older than N days. 0 = never rotate.
CHAT_LOG_RETENTION_DAYS=90

# ── Sanctum SPA stateful + CORS ────────────────────────────────────────────
# Comma-separated list of bare hosts (no scheme, optional port) that are
# allowed to authenticate via session cookies. Must include every origin
# the React SPA is served from in dev/stage/prod.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,localhost:8000,127.0.0.1,127.0.0.1:8000

# Comma-separated list of FULL origins (with scheme) allowed to send
# credentialed requests. Must match SANCTUM_STATEFUL_DOMAINS host-by-host.
# Wildcard '*' is invalid when supports_credentials=true (CORS spec).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# Two-factor authentication feature flag. Stubbed in PR2 (Phase B) — the
# TwoFactorController returns 501 until a later PR wires the full flow.
AUTH_2FA_ENABLED=false

# ── RBAC (PR3) ────────────────────────────────────────────────────────────
# Master switch for the AccessScopeScope global scope + EnsureProjectAccess
# middleware. Leave `true` in production. Set to `false` only for migration
# windows or emergency rollback — all project/document ACL enforcement turns
# into no-ops, and only PR2 authentication remains active.
RBAC_ENFORCED=true

# ── Mail (required only for password reset) ───────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Canonical KB (compilation layer) ──────────────────────────────────────
# Enables frontmatter-parsing and canonical-document awareness at retrieval
# time. Leave true even with zero canonical docs — the feature gracefully
# no-ops. Turn off (false) only for strict back-compat testing.
KB_CANONICAL_ENABLED=true
# KB_CANONICAL_DEFAULT_TYPE= (leave unset — for future use only)
KB_CANONICAL_PRIORITY_WEIGHT=0.003
KB_CANONICAL_SUPERSEDED_PENALTY=0.40
KB_CANONICAL_DEPRECATED_PENALTY=0.40
KB_CANONICAL_ARCHIVED_PENALTY=0.60
KB_CANONICAL_AUDIT_ENABLED=true

# ── Knowledge graph (wikilink-derived) ────────────────────────────────────
# 1-hop wikilink graph expansion during retrieval. No-op when no canonical
# docs / wikilinks exist. Set KB_GRAPH_EXPANSION_ENABLED=false to disable.
KB_GRAPH_EXPANSION_ENABLED=true
KB_GRAPH_EXPANSION_HOPS=1
KB_GRAPH_EXPANSION_MAX_NODES=20
KB_GRAPH_EXPANSION_EDGE_TYPES=depends_on,implements,decision_for,related_to,supersedes

# ── Anti-repetition memory (rejected-approach injection) ──────────────────
# Injects rejected-approach docs into the prompt with a ⚠ marker when the
# query correlates (cosine >= min_similarity). No-op when no rejected docs.
KB_REJECTED_INJECTION_ENABLED=true
KB_REJECTED_INJECTION_MAX_DOCS=3
KB_REJECTED_MIN_SIMILARITY=0.45

# ── Promotion pipeline (raw → curated → canonical) ────────────────────────
# POST /api/kb/promotion/{suggest|candidates|promote}. Human-gated: skills
# produce drafts, only explicit promote/kb:promote writes to the KB disk.
KB_PROMOTION_ENABLED=true

# ── Admin PDF export (Phase G4) ──────────────────────────────────────────
# Drives app/Services/Admin/Pdf/PdfRenderer selection via
# app/Services/Admin/Pdf/PdfRendererFactory.
#   disabled     = 501 response (default). Safe, no external deps.
#   dompdf       = requires `composer require dompdf/dompdf`.
#   browsershot  = requires `composer require spatie/browsershot` +
#                  Node.js + Chromium on the host.
ADMIN_PDF_ENGINE=disabled

# ── Admin Maintenance command runner (Phase H2) ───────────────────────────
# The /api/admin/commands/* endpoints ship a whitelisted Artisan runner
# (see config/admin.php `allowed_commands`). Every destructive command
# requires a Preview-issued `confirm_token`: a 64-char random string,
# DB-backed in `admin_command_nonces`, single-use + TTL-bounded. NO
# separate signing secret is used — the nonce row IS the signature, so
# APP_KEY is enough for all cryptographic needs.
#
#   ADMIN_COMMAND_TOKEN_TTL       confirm_token lifetime (seconds).
#                                 Default 300 (5 min). Keep short: the
#                                 whole point is that a human just
#                                 confirmed the action intent.
#   ADMIN_AUDIT_RETENTION_DAYS    `admin-audit:prune` keeps rows newer
#                                 than this (default 365 days).
#   ADMIN_NONCE_RETENTION_DAYS    `admin-nonces:prune` purges expired /
#                                 used nonces older than this
#                                 (default 1 day).
ADMIN_COMMAND_TOKEN_TTL=300
ADMIN_AUDIT_RETENTION_DAYS=365
ADMIN_NONCE_RETENTION_DAYS=1

# ── PII redaction (W4.1 — padosoft/laravel-pii-redactor v1.1+) ─────────────
# AskMyDocs integrates the standalone PII redactor package for chat persistence
# + embedding cache + insights snippet redaction. Every knob is OFF by default
# — v3 hosts upgrading to v4.1 see zero behaviour change until they explicitly
# enable redaction. See config/kb.php `pii_redactor` block for the full
# touch-point map.
#
#   KB_PII_REDACTOR_ENABLED       Master switch. Off → all integration
#                                 knobs below are no-ops regardless of
#                                 their individual values.
#   KB_PII_REDACT_PERSIST         Run redactor on chat_logs / messages
#                                 BEFORE insert (Tokenise strategy →
#                                 reversible via DatabaseTokenStore).
#                                 Requires the package's `database`
#                                 token store driver + the package's
#                                 `pii_token_maps` migration.
#   KB_EMBEDDINGS_PII_REDACT      Run redactor BEFORE handing text to
#                                 the embedding provider (Mask strategy
#                                 — embeddings are one-way).
#   KB_INSIGHTS_PII_REDACT        Run redactor on chat snippets BEFORE
#                                 persisting into admin_insights_snapshots
#                                 (Mask strategy — snapshots surface in
#                                 the admin dashboard).
#   KB_PII_DETOKENIZE_PERMISSION  Spatie permission required to detokenise
#                                 (default 'pii.detokenize').
#
# The package's OWN config (detectors, packs, NER drivers, token store)
# uses PII_REDACTOR_* env vars — those are documented in the
# vendor:publish pii-redactor-config output. The KB_* vars above are the
# AskMyDocs integration layer, not the package config.
KB_PII_REDACTOR_ENABLED=false
KB_PII_REDACT_PERSIST=false
KB_EMBEDDINGS_PII_REDACT=false
KB_INSIGHTS_PII_REDACT=false
# v4.6 — connector ingest boundary. When true,
# `App\Connectors\HostIngestionBridge::redactContent()` applies the
# redactor (Mask strategy) to every document body a `padosoft/askmydocs-
# connector-*` package fetched BEFORE it lands on the KB disk. Default
# off so existing connector users see no behaviour change.
KB_CONNECTOR_INGEST_PII_REDACT=false
KB_PII_DETOKENIZE_PERMISSION=pii.detokenize

# v4.3/W1 sub-PR 4.5 — comprehensive boundary coverage. Five additional
# default-OFF knobs that wire the redactor into every persistence boundary
# where chat / document / operator content could leak PII to operators,
# logs, queues, or downstream systems. v4.0/v4.1/v4.2 hosts upgrading to
# v4.3 see zero behaviour change until they explicitly opt in.
#
#   KB_PII_REDACT_LOGS            Run a Monolog processor that strips PII
#                                 from `Log::*` calls BEFORE the line hits
#                                 disk. Mask strategy (logs are forensic;
#                                 we don't need round-trip detokenisation).
#   KB_PII_REDACT_FAILED_JOBS     `Queue::failing` listener that re-saves
#                                 the `failed_jobs.payload` JSON through
#                                 RedactorEngine. Catches PII serialised
#                                 into constructor args of failed jobs.
#   KB_PII_REDACT_ANSWERS         Apply redaction to `chat_logs.answer`
#                                 and `chat_logs.sources` JSON (citation
#                                 snippets) on insert. The LLM output may
#                                 echo PII from the ingested corpus.
#   KB_PII_REDACT_COMMAND_AUDIT   `creating` observer on AdminCommandAudit
#                                 that redacts `stdout_head`, `error_message`,
#                                 and `args_json` values before insert.
#                                 Operators may pass paths / IDs / emails
#                                 as command args.
#   KB_PII_REDACT_FLOW_PAYLOADS   Bind App\Pii\AskMyDocsFlowPayloadRedactor
#                                 as the laravel-flow CurrentPayloadRedactorProvider
#                                 implementation, so EVERY persisted Flow
#                                 payload (run input, step results, audit
#                                 trail, webhook outbox) gets redacted in
#                                 one wire — comprehensive coverage.
KB_PII_REDACT_LOGS=false
KB_PII_REDACT_FAILED_JOBS=false
KB_PII_REDACT_ANSWERS=false
KB_PII_REDACT_COMMAND_AUDIT=false
KB_PII_REDACT_FLOW_PAYLOADS=false

# ── PII Redactor Admin SPA (W4 sub-PR 5 — padosoft/laravel-pii-redactor-admin v1.0.2) ──
# Mounts the full PII Redactor admin console (Dashboard, Playground,
# Token map, Detokenise, Audit logs, Detectors, Custom rules) under
# /admin/pii-redactor inside the AskMyDocs admin shell. Disabled by
# default; flip to true when the operator audience is trusted and the
# Spatie roles `super-admin` / `dpo` / `admin` are seeded (RbacSeeder
# does this automatically on fresh installs from v4.2 onward).
#
#   PII_REDACTOR_ADMIN_ENABLED       Master switch. False → no routes
#                                    are registered. The route returns
#                                    404 (correct semantic per R14).
#   PII_REDACTOR_ADMIN_ROUTE_PREFIX  Web mount path. Default keeps the
#                                    SPA next to other admin surfaces.
#   PII_REDACTOR_ADMIN_API_PREFIX    JSON API mount path.
#   PII_REDACTOR_ADMIN_MIDDLEWARE    Comma-separated middleware list.
#                                    Defaults include `can:viewPiiRedactorAdmin`
#                                    — the outer fence Gate that
#                                    AppServiceProvider wires against
#                                    Spatie roles (super-admin / dpo /
#                                    admin can view; super-admin / dpo
#                                    can detokenise; super-admin only
#                                    can see raw scan samples).
PII_REDACTOR_ADMIN_ENABLED=false
PII_REDACTOR_ADMIN_ROUTE_PREFIX=admin/pii-redactor
PII_REDACTOR_ADMIN_API_PREFIX=admin/pii-redactor/api
# PII_REDACTOR_ADMIN_MIDDLEWARE=web,auth,can:viewPiiRedactorAdmin
# PII_REDACTOR_ADMIN_SCAN_THROTTLE=30,1
# PII_REDACTOR_ADMIN_REDACT_THROTTLE=30,1
# PII_REDACTOR_ADMIN_DETOKENISE_THROTTLE=6,1
# PII_REDACTOR_ADMIN_TOKEN_MAPS_PER_PAGE=25

# ── PII redactor package (padosoft/laravel-pii-redactor) ──────────────────
# Package's own env vars. The package ships ItalyPack enabled by default —
# but in AskMyDocs the integration layer (KB_PII_REDACTOR_ENABLED above) is
# the master gate. Hosts that want redaction active set BOTH the AskMyDocs
# integration knobs AND the package vars below; hosts that don't enable
# the AskMyDocs integration leave these commented (no-op).
# PII_REDACTOR_ENABLED=false                    # default false — flip to true when KB_PII_REDACTOR_ENABLED=true
# PII_REDACTOR_STRATEGY=mask                    # mask | hash | tokenise | drop
# PII_REDACTOR_SALT=base64-of-32-random-bytes   # REQUIRED for hash / tokenise
# PII_REDACTOR_AUDIT_TRAIL_V2=false             # PiiRedactionPerformed event
# PII_REDACTOR_TOKEN_STORE=memory             # memory (default) | database | cache
# PII_REDACTOR_TOKEN_STORE_CONNECTION=null    # database driver: null = host's default
# PII_REDACTOR_TOKEN_STORE_TABLE=pii_token_maps
# PII_REDACTOR_TOKEN_STORE_CACHE_STORE=null   # cache driver: null = host's default
# PII_REDACTOR_TOKEN_STORE_CACHE_PREFIX=pii_token:
# PII_REDACTOR_TOKEN_STORE_CACHE_TTL=0        # seconds; 0 = forever
# PII_REDACTOR_NER_ENABLED=false              # opt-in for HuggingFace / spaCy
# PII_REDACTOR_NER_DRIVER=stub                # stub | huggingface | spacy
# PII_REDACTOR_HUGGINGFACE_API_KEY=hf_xxx
# PII_REDACTOR_SPACY_SERVER_URL=https://your-spacy-server.example/ner

# ── Laravel Flow package (padosoft/laravel-flow) ──────────────────────────
# Saga / compensation / approval / webhook engine. v4.2/W2 ships the
# package as a runtime dependency (sub-PR 3a). Actual orchestration of
# AskMyDocs jobs (IngestDocumentJob, CanonicalIndexer, scheduled
# commands, etc.) lands in sub-PRs 3b/3c/3d. The persistence /
# audit / webhook / approval features stay OFF until those PRs wire them.

# Persistence — when true, every Flow run + step + audit row is written
# to the configured storage. Required for replay, approval gates,
# webhook outbox, and the flow-admin dashboard. Leave false until the
# orchestration sub-PRs land.
# LARAVEL_FLOW_PERSISTENCE_ENABLED=false
# LARAVEL_FLOW_STORAGE=null                       # null = host's default DB connection
# LARAVEL_FLOW_RETENTION_DAYS=                    # blank = keep forever

# Payload redaction inside Flow's persistence (pre-pii-redactor wire-in).
# These keys are scrubbed from JSON payloads before write. The full
# pii-redactor integration via CurrentPayloadRedactorProvider lands in
# sub-PR 4.5; until then this minimal allowlist is the only protection.
# LARAVEL_FLOW_REDACTION_ENABLED=true
# LARAVEL_FLOW_REDACTION_REPLACEMENT=[redacted]

# Queue execution — Flow::dispatch() queues a RunFlowJob with a
# per-dispatch cache lock. lock_store MUST be a shared atomic store
# (Redis or database) when QUEUE_CONNECTION!=sync; the array store is
# accepted only for sync.
# LARAVEL_FLOW_QUEUE_LOCK_STORE=null              # null = host's default cache store
# LARAVEL_FLOW_QUEUE_LOCK_SECONDS=3600
# LARAVEL_FLOW_QUEUE_LOCK_RETRY_SECONDS=30
# LARAVEL_FLOW_QUEUE_TRIES=                       # blank = use Laravel default
# LARAVEL_FLOW_QUEUE_BACKOFF_SECONDS=             # blank = use Laravel default

# Approval gates — operator-controlled pause/resume. Token TTL caps how
# long a pending approval can sit before expiring. Tokens are stored as
# SHA-256 hashes; raw token only exists in the response of the issuing
# call.
# LARAVEL_FLOW_APPROVAL_TOKEN_TTL_MINUTES=1440    # 24h default

# Audit trail — when true, normal-case state transitions dispatch the
# matching Laravel event. Persisted flow_audit rows additionally require
# LARAVEL_FLOW_PERSISTENCE_ENABLED=true and a non-dry-run execution.
# LARAVEL_FLOW_AUDIT_ENABLED=true

# Dry-run default — when true, Flow::execute() with no explicit dry-run
# flag still simulates. Guard rail for staging environments where you
# want operators to opt INTO real persistence.
# LARAVEL_FLOW_DRY_RUN_DEFAULT=false

# Webhook outbox — signed lifecycle delivery to external systems.
# AskMyDocs uses this to notify downstream doc-versioning / audit
# systems when canonical promotions land (sub-PR 3c).
# LARAVEL_FLOW_WEBHOOK_ENABLED=false
# LARAVEL_FLOW_WEBHOOK_URL=
# LARAVEL_FLOW_WEBHOOK_SECRET=                    # HMAC signing secret
# LARAVEL_FLOW_WEBHOOK_RETRY_BASE_DELAY_SECONDS=30
# LARAVEL_FLOW_WEBHOOK_MAX_ATTEMPTS=3
# LARAVEL_FLOW_WEBHOOK_TIMEOUT_SECONDS=5

# Step timeout — informational only at v1.0; reserved for the queued
# step worker introduced in v0.2 of the orchestration plan.
# LARAVEL_FLOW_STEP_TIMEOUT=300

# ── Flow Admin SPA (padosoft/laravel-flow-admin v1.0.0) ───────────────────
# Operator cockpit for the laravel-flow engine: KPI dashboard, runs index,
# run detail (timeline / Gantt / DAG), approvals inbox, webhook outbox,
# flow definitions, settings. Mounted at /admin/flows inside the AskMyDocs
# admin shell (iframe — Blade + Alpine package, not React). Disabled by
# default; flip to true once the operator audience is trusted and the
# Spatie roles `super-admin` / `admin` / `dpo` are seeded (RbacSeeder
# does this automatically on fresh installs from v4.2 onward).
#
#   FLOW_ADMIN_ENABLED       Master switch. False → no routes resolve
#                            (flow-admin.enabled middleware aborts 404).
#                            R14 — correct semantic for a disabled subsystem.
#   FLOW_ADMIN_PREFIX        Web mount path. Defaults to admin/flows so the
#                            cockpit nests under the existing admin shell.
#   FLOW_ADMIN_MIDDLEWARE    Comma-separated middleware list. AskMyDocs
#                            default prepends `flow-admin.enabled` and
#                            appends `can:viewFlowAdmin` (Spatie role gate).
#   FLOW_ADMIN_ADAPTER       `eloquent` (prod, reads flow_* tables) or
#                            `array` (deterministic seed-42 fixtures —
#                            Playwright E2E only).
#   FLOW_ADMIN_POLLING_MS    Auto-refresh cadence (default 4000ms).
#   FLOW_ADMIN_THEME         `dark` (default) or `light`. Cookie-overridable.
#   FLOW_ADMIN_STEP_VIZ      `timeline` (default), `gantt`, or `dag`.
FLOW_ADMIN_ENABLED=false
FLOW_ADMIN_PREFIX=admin/flows
# FLOW_ADMIN_MIDDLEWARE=web,auth,flow-admin.enabled,can:viewFlowAdmin
# FLOW_ADMIN_ADAPTER=eloquent
# FLOW_ADMIN_POLLING_MS=4000
# FLOW_ADMIN_THEME=dark
# FLOW_ADMIN_STEP_VIZ=timeline

# Compensation strategy — reverse-order is the standard saga rollback
# pattern (newest completed step first). parallel batches independent
# compensators via Laravel Concurrency; only safe when compensators
# are independent + idempotent.
# LARAVEL_FLOW_COMPENSATION=reverse-order         # reverse-order | parallel
# LARAVEL_FLOW_COMPENSATION_PARALLEL_DRIVER=process

# =============================================================================
# padosoft/eval-harness — RAG regression CI gate (W3 / sub-PR 4)
# =============================================================================
# eval-harness drives a golden Q&A set through the AskMyDocs RAG pipeline
# (KbSearchService + GraphExpander + RejectedApproachInjector + AiManager) on
# every PR via .github/workflows/rag-regression.yml. Defaults below are
# tuned for CI: deterministic, no real provider calls, ~3 min budget.
#
# Live mode (real provider tokens) is opt-in: set EVAL_LIVE_AI=1 locally OR
# trigger the workflow via `workflow_dispatch` with `live_ai=true`.

# Live AI gate — when false (default) the registrar binds Http::fake() so
# the chat + embeddings providers never touch the network. Burning real
# tokens on every PR is unacceptable.
EVAL_LIVE_AI=false

# Default batch profile used by `eval-harness:run rag.askmydocs.factuality.fy2026`.
# - `smoke`   — 5 questions, dev iteration (~10 s)
# - `ci`      — 40+ questions, PR gate budget (~3 min)
# - `nightly` — full set + adversarial + LLM-as-judge (~15 min)
EVAL_HARNESS_BATCH_PROFILE=ci

# Reports storage — lives under storage/app/ (default disk). The CI workflow
# uploads them as artifacts; the future eval-harness-admin SPA reads them
# through the read-only API (toggle EVAL_HARNESS_API_ENABLED to enable).
EVAL_HARNESS_REPORTS_DISK=local
EVAL_HARNESS_REPORTS_PATH=eval-harness/reports

# Read-only report API — disabled by default. Sub-PR 7 (eval-harness-admin
# SPA) will enable this behind admin RBAC middleware.
EVAL_HARNESS_API_ENABLED=false
EVAL_HARNESS_API_PREFIX=admin/eval-harness/api

# LLM-as-judge / cosine-embedding wire targets. In CI mode (EVAL_LIVE_AI=false)
# the registrar swaps both for Http::fake() so these are unused. Live mode
# falls back to OPENAI_API_KEY when EVAL_HARNESS_*_API_KEY is empty.
# EVAL_HARNESS_JUDGE_ENDPOINT=https://api.openai.com/v1/chat/completions
# EVAL_HARNESS_JUDGE_MODEL=gpt-4o-mini
# EVAL_HARNESS_JUDGE_API_KEY=
# EVAL_HARNESS_EMBEDDINGS_ENDPOINT=https://api.openai.com/v1/embeddings
# EVAL_HARNESS_EMBEDDINGS_MODEL=text-embedding-3-small
# EVAL_HARNESS_EMBEDDINGS_API_KEY=

# Adversarial run manifest discovery — points at the disk + path the
# `eval-harness:adversarial` command writes to. Wired up so the future
# eval-harness-admin SPA can browse compliance history.
EVAL_HARNESS_ADVERSARIAL_MANIFEST_DISK=local
EVAL_HARNESS_ADVERSARIAL_MANIFEST_PATH=eval-harness/adversarial/manifests

# Provider retries — default 0 (fail fast in CI). Bump to 2 in nightly
# only if the live LLM provider is flaky.
EVAL_HARNESS_PROVIDER_RETRY_ATTEMPTS=0
EVAL_HARNESS_PROVIDER_RETRY_SLEEP_MS=100

# v4.3/W3 — Nightly eval-harness cron (eval:nightly).
#
# Master kill-switch. When false (default) the scheduler does NOT
# register `eval:nightly` at 05:30. Flip to true on hosts with a
# provider key configured to enable the regression sentinel.
EVAL_NIGHTLY_ENABLED=false

# Live-AI override for the nightly run. Defense-in-depth: even when
# EVAL_NIGHTLY_ENABLED=true, the command refuses to override
# EVAL_LIVE_AI unless EVAL_NIGHTLY_LIVE=true AND a provider key is
# present (OPENAI_API_KEY / EVAL_HARNESS_JUDGE_API_KEY / ...).
EVAL_NIGHTLY_LIVE=false

# Macro-F1 regression alert threshold. When the new run's macro_f1
# drops by more than this fraction relative to the prior baseline,
# the command writes a sidecar JSON and fires Log::alert(). Range
# [0..1]; values outside fall back to the default 0.05 (5%).
EVAL_NIGHTLY_REGRESSION_THRESHOLD=0.05

# Retention window (days) for the dated reports under
# storage/app/eval-harness/nightly/. The command prunes older files
# automatically at the end of every successful run; --prune-only
# triggers a sweep without running the eval.
EVAL_NIGHTLY_RETENTION_DAYS=90

# v4.4/W4 — Adversarial nightly opt-in (ADR 0007).
#
# Master gate for the adversarial nightly pass. Default false: when
# unset/false, eval:nightly runs the baseline factuality dataset
# only — bit-identical to the v4.3/W3 path. When true, AFTER the
# baseline run succeeds the command additionally runs each enabled
# adversarial dataset (out-of-corpus / contradicting-claims /
# rejected-approach-trigger) and writes a per-slug summary sidecar.
# Adversarial regressions are advisory ONLY (no Log::alert) — the
# baseline remains the single loud alert surface. A baseline failure
# skips the adversarial pass entirely.
EVAL_NIGHTLY_ADVERSARIAL=false

# Comma-separated allowlist of adversarial slugs to run when
# EVAL_NIGHTLY_ADVERSARIAL=true. Leave empty to run every configured
# adversarial dataset. Valid slug keys come from
# config('eval-harness.askmydocs.golden.adversarial'); unknown slugs
# are skipped with a Log::warning so operator typos surface loudly.
# Example: EVAL_NIGHTLY_ADVERSARIAL_DATASETS=out-of-corpus,rejected-approach-trigger
EVAL_NIGHTLY_ADVERSARIAL_DATASETS=

# ── Eval Harness UI SPA (W4 sub-PR 7 — padosoft/eval-harness-ui v1.0.0) ────
# Mounts the read-only eval dashboard (Dashboard, Reports list, Report
# detail, Compare, Trend, Adversarial manifests + details, Live batches)
# under /admin/eval-harness inside the AskMyDocs admin shell. Disabled
# by default; flip to true only on dev / staging / QA. Two fences keep
# the dashboard out of production:
#
#   1. EVAL_HARNESS_UI_ENABLED=false (default) → package controller
#      returns 404.
#   2. APP_ENV=production → host-app `eval-harness-ui.non-prod`
#      middleware returns 404 even if EVAL_HARNESS_UI_ENABLED=true.
#
# Either fence alone is enough; both must be open for the SPA to
# render. The dashboard is read-only — no mutation endpoints — so a
# single Gate `eval-harness.viewer` (super-admin / admin / dpo /
# editor) backs the route. Wired in
# AppServiceProvider::registerEvalHarnessUiGates().
#
#   EVAL_HARNESS_UI_ENABLED      Master switch. False → package
#                                controller returns 404 (R14: correct
#                                semantic for a disabled subsystem).
#   EVAL_HARNESS_UI_PREFIX       Web mount path. Default keeps the SPA
#                                next to other admin surfaces.
#   EVAL_HARNESS_API_BASE        Backend report-API base URL forwarded
#                                to the SPA bootstrap payload.
#   EVAL_HARNESS_TENANT_HEADER   HTTP header carrying the active tenant
#                                id; auto-populated from TenantContext
#                                by `eval-harness-ui.tenant-header`
#                                middleware (R30).
#   EVAL_HARNESS_UI_LOCALE       UI locale (en | it). Defaults to
#                                APP_LOCALE.
EVAL_HARNESS_UI_ENABLED=false
EVAL_HARNESS_UI_PREFIX=admin/eval-harness
# EVAL_HARNESS_API_BASE=/admin/eval-harness/api
# EVAL_HARNESS_TENANT_HEADER=X-Eval-Harness-Tenant
# EVAL_HARNESS_UI_LOCALE=en

# ── Connector framework (v4.5/W1) ──────────────────────────────────────────
# Cadence + queue knobs for the pluggable external-source connector
# framework (Google Drive, Notion, Evernote, Fabric, OneDrive,
# Confluence, Jira, ...). See config/connectors.php +
# docs/connectors/README.md.
#
#   CONNECTOR_DEFAULT_SYNC_CADENCE_MINUTES   How often the scheduler
#                                            dispatches a sync job per
#                                            active installation (per-
#                                            connector overrides live
#                                            in config/connectors.php).
#   CONNECTOR_OAUTH_STATE_TTL_SECONDS        TTL for the CSRF state
#                                            token stored in the cache
#                                            during the OAuth round-trip.
#   CONNECTOR_SYNC_JOB_QUEUE                 Queue name for
#                                            ConnectorSyncJob (defaults
#                                            to the host's default
#                                            queue).
CONNECTOR_DEFAULT_SYNC_CADENCE_MINUTES=15
CONNECTOR_OAUTH_STATE_TTL_SECONDS=600
CONNECTOR_SYNC_JOB_QUEUE=default

# ── Connector: Google Drive (reference, v4.5/W1) ───────────────────────────
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# → Application type: Web application → Authorized redirect URIs must
# include the CONNECTOR_GOOGLE_DRIVE_REDIRECT_URI value below. Scopes
# requested: drive.readonly + drive.metadata.readonly.
#
#   CONNECTOR_GOOGLE_DRIVE_CLIENT_ID       OAuth2 client id from GCP
#   CONNECTOR_GOOGLE_DRIVE_CLIENT_SECRET   OAuth2 client secret from GCP
#   CONNECTOR_GOOGLE_DRIVE_REDIRECT_URI    Absolute URL of the host's
#                                          OAuth callback route (defaults
#                                          to APP_URL +
#                                          /api/admin/connectors/google-drive/oauth/callback).
# CONNECTOR_GOOGLE_DRIVE_CLIENT_ID=
# CONNECTOR_GOOGLE_DRIVE_CLIENT_SECRET=
# CONNECTOR_GOOGLE_DRIVE_REDIRECT_URI=

# ── Connector: Notion (reference, v4.5/W2) ─────────────────────────────────
# Register a public integration at https://www.notion.so/my-integrations
# → Choose "Public integration" → fill OAuth Domain & Authorization URI.
# The integration is workspace-scoped (Notion calls it "Public Integration");
# operators choose which pages to share with the integration during install.
# Notion access tokens DO NOT expire — there is no refresh-token flow.
# Notion does NOT expose a programmatic revoke endpoint; disconnect()
# clears local credentials only. Full revocation happens inside the
# Notion workspace settings → Connections → Disconnect.
#
#   CONNECTOR_NOTION_CLIENT_ID       OAuth2 client id from the Notion
#                                    public-integration settings page.
#   CONNECTOR_NOTION_CLIENT_SECRET   OAuth2 client secret from same page.
#   CONNECTOR_NOTION_REDIRECT_URI    Absolute URL of the host's OAuth
#                                    callback route (defaults to APP_URL +
#                                    /api/admin/connectors/notion/oauth/callback).
# CONNECTOR_NOTION_CLIENT_ID=
# CONNECTOR_NOTION_CLIENT_SECRET=
# CONNECTOR_NOTION_REDIRECT_URI=

# --- Jira Cloud (v4.5/W6) ---
# Atlassian OAuth 2.0 3LO — same surface as Confluence; a single
# workspace can install both connectors against the same `cloud_id`.
# Create an OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# → "Create" → "OAuth 2.0 integration" → add the "Jira API" → enable
# scopes `read:jira-work`, `read:jira-user`, `offline_access` →
# Authorization → set the callback URL to APP_URL + the redirect URI
# below. Atlassian DOES expose a programmatic revoke endpoint; the
# connector calls it best-effort on disconnect() for BOTH access and
# refresh tokens.
#
#   CONNECTOR_JIRA_CLIENT_ID         OAuth2 client id from the
#                                    developer console.
#   CONNECTOR_JIRA_CLIENT_SECRET     OAuth2 client secret from the
#                                    same page.
#   CONNECTOR_JIRA_REDIRECT_URI      Absolute URL of the host's OAuth
#                                    callback (defaults to APP_URL +
#                                    /api/admin/connectors/jira/oauth/callback).
# CONNECTOR_JIRA_CLIENT_ID=
# CONNECTOR_JIRA_CLIENT_SECRET=
# CONNECTOR_JIRA_REDIRECT_URI=


# =============================================================================
# AI Act compliance v1.2 → v1.5 — opt-in feature knobs (v6.1.1)
# =============================================================================
#
# All four capabilities below default OFF — flip ONLY what you need.
# Sister-package config is published into config/ai-act-compliance.php by
# running:
#
#   php artisan vendor:publish --tag=ai-act-compliance-config
#
# The host (.env) wins over the published file; the published file wins
# over the package's baked-in defaults.
#
# --- v1.3 — Cohort-drift real-time alerting cascade ---------------------------
# When AI_ACT_ALERTING_ENABLED=true:
#   1. The package's `BiasDriftDetectedListener` (queued) fans every
#      `BiasDriftDetected` event out as Slack → Discord → email per row
#      in the `alert_routes` table.
#   2. AskMyDocs ships zero `alert_routes` rows out of the box. Seed one
#      per channel you want before going live — see the package README
#      §4 "Real-time alerting cascade".
#   3. Set `queue.default` to something that actually runs (database /
#      redis / sync) — under the `sync` driver alerts fire synchronously
#      on the request thread.
#
# AI_ACT_ALERTING_ENABLED=false
# AI_ACT_ALERT_THROTTLE_MINUTES=60        # per-tenant cohort cooldown
# AI_ACT_ALERT_CB_FAILURES=5              # consecutive failures before tripping
# AI_ACT_ALERT_CB_COOLDOWN=30             # minutes a tripped channel waits
# AI_ACT_ALERT_EVIDENCE_URL_TEMPLATE=
#   # Optional: persisted on every alert as a click-through DPO inspect
#   # link. Supports `{tenant_id}`, `{metric_name}`, `{cohort}` placeholders.
#   # Example: %APP_URL%/admin/ai-act-compliance/bias?tenant={tenant_id}&metric={metric_name}
#
# --- v1.4 — Regulatory-feed auto-flagger -------------------------------------
# When AI_ACT_REGULATORY_FEED_ENABLED=true:
#   1. `bootstrap/app.php` schedules `ai-act:regulatory-poll` daily at
#      04:10 (idempotent, single-server). The Artisan command is also
#      callable on demand.
#   2. The poller hits every driver listed under
#      `regulatory_feed.drivers` in the package config. The default
#      driver `eu-ai-act-rss` reads `AI_ACT_REGULATORY_FEED_URL`.
#   3. Each new amendment is persisted under the active tenant id
#      (or NULL for the platform-global tenant) and fires the
#      `RegulatoryAmendmentDetected` event so downstream listeners
#      (e.g. auto-open a `RiskRegisterEntry`) can hook in.
#
# AI_ACT_REGULATORY_FEED_ENABLED=false
# AI_ACT_REGULATORY_FEED_URL=https://eur-lex.europa.eu/EN/legal-content/summaries/AI-act.xml
# AI_ACT_REGULATORY_FEED_MAX_ENTRIES=50    # per-poll cap (0 = no entries)
# AI_ACT_REGULATORY_FEED_TIMEOUT=15        # HTTP request timeout seconds
#
# --- v1.5 — DPO multi-org tenant management ----------------------------------
# When the operator persists rows in the `tenants` table:
#   1. The `ai-act.tenant-context` middleware alias resolves the
#      requested tenant from `X-Tenant-Id` (or `?tenant=` fallback).
#      Unknown → 404; suspended → 423 Locked; archived → 410 Gone.
#   2. `App\Compliance\TenantContextBridge` propagates AskMyDocs's
#      host tenant id into the sister-package context so per-tenant
#      `config_overrides_json` resolves under the right tenant.
#   3. AskMyDocs does NOT auto-create `tenants` rows. Operators create
#      them via:  POST /api/admin/ai-act-compliance/tenants
#                 { "slug": "acme", "name": "Acme Inc.",
#                   "subscription_tier": "enterprise",
#                   "dpo_email": "dpo@acme.example" }
#
# No env vars to set — v1.5 is config-driven via the `tenants` table
# and the package's `ai-act-compliance.tenants.*` block.
#
# --- v1.2 — Pluggable bias-metric registry -----------------------------------
# AI_ACT_BIAS_DEFAULT_METRIC=demographic_parity   # alt: equalized_odds | calibration
# AI_ACT_BIAS_DISPARITY_THRESHOLD=0.05            # drift threshold (0..1)
# AI_ACT_BIAS_MIN_SAMPLE_SIZE=30                  # hint, metrics never reject smaller cohorts
