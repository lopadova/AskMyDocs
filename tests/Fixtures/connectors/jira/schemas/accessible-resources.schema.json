{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Atlassian OAuth — /accessible-resources response",
    "type": "array",
    "items": {
        "type": "object",
        "required": ["id", "scopes"],
        "properties": {
            "id": {"type": "string", "minLength": 1},
            "name": {"type": ["string", "null"]},
            "url": {"type": ["string", "null"]},
            "scopes": {
                "type": "array",
                "items": {"type": "string"}
            }
        }
    }
}
