{
    "name": "padosoft/askmydocs",
    "description": "AskMyDocs - Enterprise AI Knowledge Base (RAG) on Laravel.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.2",
        "league/commonmark": "^2.5",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0"
    },
    "suggest": {
        "predis/predis": "^2.0 — required when QUEUE_CONNECTION=redis (used by kb:ingest-folder and POST /api/kb/ingest)",
        "laravel/horizon": "^5.0 — optional Redis queue dashboard for monitoring ingestion workers",
        "league/flysystem-aws-s3-v3": "^3.0 — required when KB_FILESYSTEM_DISK=s3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
