{
  "name": "askmydocs",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b frontend/tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:legacy": "vitest run --config vitest.config.mjs",
    "test:all": "npm run test:legacy && npm run test",
    "typecheck": "tsc -p frontend/tsconfig.json --noEmit && tsc -p frontend/tsconfig.node.json --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.173",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.0",
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-router": "^1.81.5",
    "ai": "^6.0.171",
    "axios": "^1.7.7",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.53.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "laravel-vite-plugin": "^1.0.5",
    "remark-parse": "^11.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
