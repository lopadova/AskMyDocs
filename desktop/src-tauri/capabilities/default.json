{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window: opener + scoped HTTP to the AskMyDocs backend (production + local) + local store.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://askmydocs.surfacesrl.com/*" },
        { "url": "https://askmydocs.test/*" },
        { "url": "http://localhost:8000/*" },
        { "url": "http://127.0.0.1:8000/*" },
        { "url": "http://192.168.*.*:*/*" },
        { "url": "https://192.168.*.*:*/*" },
        { "url": "http://10.*.*.*:*/*" },
        { "url": "https://10.*.*.*:*/*" }
      ]
    }
  ]
}
